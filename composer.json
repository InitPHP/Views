{
    "name": "initphp/views",
    "description": "A small, adapter-based view rendering layer for PHP with PurePHP, Blade and Twig back-ends.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "view",
        "views",
        "template",
        "template-engine",
        "rendering",
        "blade",
        "twig",
        "php",
        "initphp"
    ],
    "authors": [
        {
            "name": "Muhammet ŞAFAK",
            "email": "info@muhammetsafak.com.tr",
            "role": "Developer",
            "homepage": "https://www.muhammetsafak.com.tr"
        }
    ],
    "support": {
        "issues": "https://github.com/InitPHP/Views/issues",
        "source": "https://github.com/InitPHP/Views",
        "docs": "https://github.com/InitPHP/Views/tree/main/docs"
    },
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "phpstan/phpstan": "^1.12 || ^2.1",
        "friendsofphp/php-cs-fixer": "^3.65",
        "illuminate/view": "^9.0 || ^10.0 || ^11.0",
        "illuminate/events": "^9.0 || ^10.0 || ^11.0",
        "illuminate/filesystem": "^9.0 || ^10.0 || ^11.0",
        "twig/twig": "^3.0"
    },
    "suggest": {
        "illuminate/view": "To render templates with the Laravel Blade engine through BladeAdapter.",
        "twig/twig": "To render templates with the Symfony Twig engine through TwigAdapter."
    },
    "autoload": {
        "psr-4": {
            "InitPHP\\Views\\": "src/"
        },
        "files": [
            "src/Helpers/View_helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "InitPHP\\Views\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html build/coverage",
        "stan": "phpstan analyse --no-progress",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "ci": [
            "@cs-check",
            "@stan",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "test": "Run the PHPUnit test suite.",
        "test-coverage": "Run PHPUnit and produce an HTML coverage report under build/coverage.",
        "stan": "Run PHPStan at the level configured in phpstan.neon.dist.",
        "cs-check": "Report any PHP-CS-Fixer violations without modifying files.",
        "cs-fix": "Apply PHP-CS-Fixer fixes in-place.",
        "ci": "Run the full CI bundle locally: cs-check, stan, test."
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}
